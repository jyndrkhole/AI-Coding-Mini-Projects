#!/usr/bin/env bash
set -euo pipefail

PROJECT_DIR="/Users/jayendra/Documents/Study/Scaler/AI Engineering/Reclaim MacOS Space"
URL="http://127.0.0.1:8765"
cd "$PROJECT_DIR"

alert() {
  osascript -e "display alert \"Reclaim Space\" message \"$1\""
}

if ! command -v python3 >/dev/null 2>&1; then
  alert "Python 3 is required. Install it from python.org or Homebrew."
  exit 1
fi

if curl -sf "$URL/api/disk" >/dev/null 2>&1; then
  open "$URL"
  exit 0
fi

if [[ ! -d .venv ]]; then
  python3 -m venv .venv
fi
# shellcheck disable=SC1091
source .venv/bin/activate
pip install -q -r requirements.txt

exec python app.py
